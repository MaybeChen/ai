{
  "compilerOptions": {
    "target": "es2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "ai": [
        "../../packages/ai/src/index.ts"
      ],
      "@ai-sdk/gateway": [
        "../../packages/gateway/src/index.ts"
      ],
      "@ai-sdk/openai-compatible": [
        "../../packages/openai-compatible/src/index.ts"
      ],
      "@ai-sdk/provider": [
        "../../packages/provider/src/index.ts"
      ],
      "@ai-sdk/provider-utils": [
        "../../packages/provider-utils/src/index.ts"
      ],
      "@ai-sdk/react": [
        "../../packages/react/src/index.ts"
      ]
    },
    "composite": true,
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "references": [
    {
      "path": "../../packages/ai"
    },
    {
      "path": "../../packages/react"
    },
    {
      "path": "../../packages/openai-compatible"
    }
  ]
}
